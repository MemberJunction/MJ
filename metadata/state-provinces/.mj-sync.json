  "defaults": {},
  "pull": {
    "createNewFileIfNotFound": true,
    "newFileName": ".state-provinces.json",
    "appendRecordsToExistingFile": true,
    "updateExistingRecords": true,
    "preserveFields": [],
    "excludeFields": [],
    "mergeStrategy": "merge",
    "backupBeforeUpdate": true,
    "backupDirectory": ".backups",
    "filter": "",
    "externalizeFields": ["BoundaryGeoJSON"],
    "ignoreNullFields": true,
    "ignoreVirtualFields": true,
    "lookupFields": {
      "CountryID": {
        "entity": "MJ: Countries",
        "matchField": "ISO2",
        "sourceField": "_CountryISO2"
      }
    },
    "relatedEntities": {}
  }
}
