[
  {
    "_comments": [
      "Runtime Actions demo #2 — permissioned metadata + view query.",
      "Uses allowAnyEntity=true so the action can accept any entity name as",
      "runtime input. Framework-authored and approved; agent-authored",
      "Runtime actions should enumerate specific entities in allowedEntities",
      "rather than set this flag."
    ],
    "fields": {
      "Name": "Entity Data Quality Report",
      "Description": "Scans a sample of records for a given entity and returns a data quality report: per-field null rates, distinct value counts, and an overall completeness score (0-1) that weights non-nullable fields 2x. Useful for data stewards triaging bad data. Exercises the `md` (entity introspection) and `rv` (RunView) bridge namespaces.",
      "Type": "Runtime",
      "Status": "Active",
      "CodeApprovalStatus": "Approved",
      "IconClass": "fa-solid fa-magnifying-glass-chart",
      "CategoryID": "@lookup:MJ: Action Categories.Name=Data",
      "Code": "@file:runtime/code/entity-data-quality-report.js",
      "RuntimeActionConfiguration": {
        "permissions": {
          "allowedActions": [],
          "allowedAgents": [],
          "allowedEntities": [],
          "allowAnyEntity": true
        },
        "limits": {
          "maxMemoryMB": 256,
          "maxBridgeCalls": 10
        }
      },
      "MaxExecutionTimeMS": 60000
    },
