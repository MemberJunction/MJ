        "permissions": {
          "allowedActions": [],
          "allowedAgents": [],
          "allowedEntities": []
        },
        "limits": {
          "maxMemoryMB": 128,
          "maxBridgeCalls": 0
        }
      },
      "MaxExecutionTimeMS": 10000
    },
