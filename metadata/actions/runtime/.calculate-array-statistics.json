[
  {
    "_comments": [
      "Runtime Actions demo #1 — pure compute. No bridge calls, exercises the",
      "sandbox + lodash library. Use this to validate the sandbox is working",
      "end-to-end before trusting any bridge-based Runtime actions."
    ],
    "fields": {
      "Name": "Calculate Array Statistics",
      "Description": "Takes an array of numbers and returns summary statistics: count, min, max, sum, mean, median, stdDev, variance, and outliers detected via n-sigma distance from the mean. Pure compute — runs entirely inside the sandbox, no MJ metadata or entity access required. Useful as a building block for numeric summarization inside agent workflows, and as a smoke test for the Runtime Actions pipeline.",
      "Type": "Runtime",
      "Status": "Active",
      "CodeApprovalStatus": "Approved",
      "IconClass": "fa-solid fa-calculator",
      "CategoryID": "@lookup:MJ: Action Categories.Name=Utilities",
      "Code": "@file:runtime/code/calculate-array-statistics.js",
