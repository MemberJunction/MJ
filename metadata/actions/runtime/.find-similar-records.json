[
  {
    "_comments": [
      "Runtime Actions demo #4 — fuzzy record matching with no AI cost.",
      "Exercises metadata introspection (to validate the field type), RunView",
      "(to pull candidates), and real compute in the sandbox (inline Levenshtein",
      "distance combined with substring-containment scoring)."
    ],
    "fields": {
      "Name": "Find Similar Records",
      "Description": "Finds records in an entity whose text field is similar to a search string. Ranks matches by a blended score (30% containment, 70% normalized Levenshtein) so both typos and long-substring matches rank well. No AI dependency — cheap and deterministic. Validates the target field via metadata before scanning.",
      "Type": "Runtime",
      "Status": "Active",
      "CodeApprovalStatus": "Approved",
      "IconClass": "fa-solid fa-magnifying-glass-location",
      "CategoryID": "@lookup:MJ: Action Categories.Name=Data",
      "Code": "@file:runtime/code/find-similar-records.js",
      "RuntimeActionConfiguration": {
        "permissions": {
          "allowedActions": [],
          "allowedAgents": [],
          "allowedEntities": [],
          "allowAnyEntity": true
        },
        "limits": {
          "maxMemoryMB": 256,
          "maxBridgeCalls": 10
        }
      },
      "MaxExecutionTimeMS": 60000
    },
