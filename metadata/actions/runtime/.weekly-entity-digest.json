[
  {
    "_comments": [
      "Runtime Actions demo #5 — the full-stack composition.",
      "Exercises rv.RunViews (parallel queries), libs.dateFns + libs.lodash,",
      "ai.ExecutePrompt (markdown-format prompt), and actions.Invoke",
      "('Send Single Message'). If this runs end-to-end, the whole Runtime",
      "Actions infrastructure is working. Supports dryRun=true so you can",
      "inspect the markdown before wiring a real recipient."
    ],
    "fields": {
      "Name": "Weekly Entity Digest",
      "Description": "Composes a weekly markdown digest from activity across one or more entities, then emails it via the Send Single Message action. Exercises every major bridge namespace: metadata-bounded entity queries (rv), standard library helpers (libs), AI prompt rendering (ai), and downstream action invocation (actions). Supports dryRun=true to return the markdown without sending.",
      "Type": "Runtime",
      "Status": "Active",
      "CodeApprovalStatus": "Approved",
      "IconClass": "fa-solid fa-newspaper",
      "CategoryID": "@lookup:MJ: Action Categories.Name=Communication",
      "Code": "@file:runtime/code/weekly-entity-digest.js",
      "RuntimeActionConfiguration": {
        "permissions": {
          "allowedActions": [
            {
              "id": "@lookup:MJ: Actions.Name=Send Single Message",
              "name": "Send Single Message"
            }
          ],
          "allowedAgents": [],
          "allowedEntities": [],
          "allowAnyEntity": true
        },
        "limits": {
          "maxMemoryMB": 256,
          "maxBridgeCalls": 20
        }
      },
      "MaxExecutionTimeMS": 180000
    },
