    "fields": {
      "Name": "Get Entity Schema For Form",
      "Description": "Read-only action consumed by the Form Builder agent. Returns the curated form-relevant schema for an entity: field list with normalised types (string | number | boolean | datetime | enum | foreign-key), FK references resolved to {entity, displayField}, value-list fields annotated with allowedValues, and audit / virtual / computed fields stripped. The shape matches the CuratedFormSchema type in @memberjunction/interactive-component-types/forms.",
      "DriverClass": "__GetEntitySchemaForForm",
      "Type": "Custom",
      "Status": "Active",
      "IconClass": "fa-solid fa-table-columns",
      "CategoryID": "@lookup:MJ: Action Categories.Name=Utilities"
    },
