  {
    "fields": {
      "Name": "Create Interactive Form",
      "Description": "Persists an AI-authored or human-authored runtime form. Lints the supplied ComponentSpec (must declare componentRole='form'), inserts a Component row with the spec, and creates an EntityFormOverride row that activates the form for the calling user. Scope is always clamped to 'User' regardless of any args — the action never writes Global or Role overrides. Returns the IDs of the persisted rows.",
      "DriverClass": "__CreateInteractiveForm",
      "Type": "Custom",
      "Status": "Active",
      "IconClass": "fa-solid fa-wand-magic-sparkles",
      "CategoryID": "@lookup:MJ: Action Categories.Name=Utilities"
    },
