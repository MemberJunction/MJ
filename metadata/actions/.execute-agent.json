[
  {
    "_comments": [
      "Generic 'Execute Agent' action — runs any top-level AIAgent (ExposeAsAction=true)",
      "via AgentRunner. Drives the ExposeAsAction catalog surface: schedulers, workflows,",
      "MCP clients, and Runtime actions invoking utilities.actions.Invoke can all call this",
      "single action with an AgentName/AgentID param instead of needing a per-agent wrapper."
    ],
    "fields": {
      "Name": "Execute Agent",
      "Description": "Executes a top-level AI Agent by name or ID using the framework's AgentRunner. Only invokable for agents with ExposeAsAction=true. Returns the AgentRunID, final payload, and full AgentResult. Sub-agents (ParentID set) cannot be invoked through this action — run the parent agent instead.",
      "DriverClass": "Execute Agent",
      "Type": "Custom",
      "Status": "Active",
      "IconClass": "fa-solid fa-robot",
      "CategoryID": "@lookup:MJ: Action Categories.Name=AI"
    },
