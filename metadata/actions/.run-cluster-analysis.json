[
  {
    "fields": {
      "Name": "Run Cluster Analysis",
      "Description": "Clusters an entity's embedding vectors (KMeans or DBSCAN), projects them to a 2D/3D layout via UMAP (PCA fallback), optionally names clusters with an LLM, and — when a PersistAs name is supplied — saves the result as an MJ: Cluster Analysis record. Thin wrapper over the framework-agnostic ClusteringEngine.",
      "DriverClass": "RunClusterAnalysisAction",
      "Type": "Custom",
      "Status": "Active",
      "IconClass": "fa-solid fa-diagram-project",
      "CategoryID": "@lookup:MJ: Action Categories.Name=AI"
    },
