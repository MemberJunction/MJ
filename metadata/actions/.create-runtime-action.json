[
  {
    "_comments": [
      "Persists a new Action record with Type='Runtime' and CodeApprovalStatus='Pending'.",
      "Called by ActionSmith at the end of its generate/test/submit pipeline. Validates",
      "the supplied RuntimeActionConfiguration via Zod before any DB write."
    ],
    "fields": {
      "Name": "Create Runtime Action",
      "Description": "Creates a new Action record with Type='Runtime'. Validates the supplied RuntimeActionConfiguration, persists the Action row (CodeApprovalStatus='Pending'), and creates companion ActionParam + ActionResultCode rows from the input/output/resultCodes payloads. The created action is NOT activated until a human approves it.",
      "DriverClass": "Create Runtime Action",
      "Type": "Custom",
      "Status": "Active",
      "IconClass": "fa-solid fa-wand-magic-sparkles",
      "CategoryID": "@lookup:MJ: Action Categories.Name=AI"
    },
