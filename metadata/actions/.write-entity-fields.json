        {
          "fields": {
            "ActionID": "@parent:ID",
            "Name": "EntityName",
            "Type": "Input",
            "ValueType": "Scalar",
            "IsArray": false,
            "Description": "The MJ entity name as registered in the metadata. Built-in MJ entities all use the 'MJ: ' prefix, e.g. 'MJ: AI Agents', 'MJ: Users', 'MJ: AI Prompt Runs'. Custom entities added by an MJ deployment may or may not use the prefix. Case-insensitive. Look up via Metadata.EntityByName if uncertain.",
            "IsRequired": true
