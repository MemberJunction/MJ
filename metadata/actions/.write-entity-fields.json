            "Name": "Fields",
            "Type": "Input",
            "ValueType": "Simple Object",
            "IsArray": false,
            "Description": "Object mapping field names to values, e.g. { \"Status\": \"Active\", \"Description\": \"Updated\" }. Only writable fields are accepted; primary keys, computed fields, and timestamps (__mj_CreatedAt, __mj_UpdatedAt) are managed automatically and should be omitted. Fields not included are left unchanged on an update. Accepts a JSON string as well.",
            "IsRequired": true
