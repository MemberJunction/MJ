[
  {
    "fields": {
      "Name": "Write Entity Field(s)",
      "Description": "Writes one or more fields onto a SINGLE entity record — either updating an existing record (identified by its PrimaryKey) or creating a new one (when CreateIfMissing=true and no PrimaryKey is supplied). A reusable write primitive for Flow Agents and as the terminal write-back step of a Feature Pipeline: give it the target entity, an optional primary key, and a field map, and it loads-or-creates, sets the fields, and saves. Respects entity validation, permissions, and audit trails (Record Changes). To always insert use Create Record; to read use Get Record / Run View.",
      "DriverClass": "WriteEntityFieldsAction",
      "Type": "Custom",
      "CategoryID": "@lookup:MJ: Action Categories.Name=Data&Parent=System",
      "Status": "Active"
    },
    "relatedEntities": {
