[
  {
    "_comments": [
      "Runs a Runtime action against one or more declared test cases, returning",
      "per-case pass/fail plus aggregated counts. Supports either an existing",
      "Action record (ActionID/ActionName) OR an ephemeral in-memory action",
      "(Code + Configuration) that hasn't been persisted yet — that path is how",
      "ActionSmith exercises freshly-generated code before calling Create Runtime",
      "Action."
    ],
    "fields": {
      "Name": "Test Runtime Action",
      "Description": "Runs a Runtime action against declared test cases. Accepts either (ActionID/ActionName) for an existing Action record or (Code + Configuration) for a freshly-generated, not-yet-persisted Runtime action. Each case runs through ActionEngine.RunAction so the full timeout / bridge / approval path is exercised. Returns per-case pass/fail plus AllPassed / PassedCount / FailedCount for the whole batch.",
      "DriverClass": "Test Runtime Action",
      "Type": "Custom",
      "Status": "Active",
      "IconClass": "fa-solid fa-vial",
      "CategoryID": "@lookup:MJ: Action Categories.Name=AI"
    },
