[
  {
    "fields": {
      "Name": "Scoped Search",
      "Description": "Scope-aware universal search for AI agents. Enforces the calling agent's SearchScopeAccess ('All' | 'Assigned' | 'None') and resolves the requested scope against the agent's AIAgentSearchScope rows. Supports agent-invoked pre-rendered query templates, per-provider query transforms, multi-scope RRF fusion, and (optional) re-ranking. Returns ranked, scored, and enriched results in the same shape as the universal Search action.",
      "DriverClass": "__Scoped_Search",
      "Type": "Custom",
      "Status": "Active",
      "IconClass": "fa-solid fa-magnifying-glass-location",
      "CategoryID": "@lookup:MJ: Action Categories.Name=Data"
    },
    "relatedEntities": {
