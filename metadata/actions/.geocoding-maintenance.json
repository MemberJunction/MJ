    "fields": {
      "Name": "Scheduled Geocoding",
      "Description": "Maintenance action that finds records missing geocodes, retries failed geocoding attempts, and cleans up orphaned RecordGeoCode rows. Processes all pending records in parallel batches with cache invalidation. Designed to run on a schedule as a safety net for records that bypass BaseEntity.Save() (bulk SQL imports, direct DB operations).",
      "DriverClass": "Scheduled Geocoding",
      "Type": "Custom",
      "Status": "Active",
      "IconClass": "fa-solid fa-map-location-dot",
      "CategoryID": "@lookup:MJ: Action Categories.Name=Data"
