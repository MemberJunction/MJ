{
  "entity": "MJ: Entity Permissions",
  "filePattern": "**/.*.json",
  "defaults": {},
  "pull": {
    "createNewFileIfNotFound": true,
    "newFileName": ".entity-permissions.json",
    "appendRecordsToExistingFile": true,
    "updateExistingRecords": true,
    "preserveFields": [],
    "excludeFields": [],
    "mergeStrategy": "merge",
    "backupBeforeUpdate": true,
    "backupDirectory": ".backups",
    "filter": "RoleID IN (SELECT ID FROM __mj.Role WHERE Name='Magic Link Baseline')",
    "externalizeFields": [],
    "ignoreNullFields": true,
    "ignoreVirtualFields": true,
    "lookupFields": {},
    "relatedEntities": {}
  }
}
