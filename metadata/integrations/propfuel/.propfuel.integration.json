              "SyncStrategy": "WatermarkIncremental",
              "SyncStrategyNote": "Mutable upsert-with-soft-delete. Record identity = checkin_question.id; in-record modified field = updated_at; soft-delete tombstone = deleted_at. Feed-level cursor is the microtime filename prefix; record-level incremental watermark is checkin_question.updated_at.",
              "IsMutable": true,
              "IsAppendOnly": false,
              "ContentHashApplicable": false,
