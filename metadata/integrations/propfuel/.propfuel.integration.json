[
  {
    "fields": {
      "Name": "PropFuel",
      "Description": "PropFuel (re:Members) member-engagement platform connector. File-feed export pull connector covering three data streams: checkin_questions (Q&A responses, mutable), clicks (link-click events, insert-only), and opens (email/message open events, insert-only). Incremental sync driven by microtime filename watermark. Read-only by default; ack cursor-advance available for production sync.",
      "ClassName": "PropFuelConnector",
      "ImportPath": "@memberjunction/integration-connectors",
      "NavigationBaseURL": "https://app.propfuel.com",
      "CredentialTypeID": "@lookup:MJ: Credential Types.Name=API Key with Endpoint",
      "Icon": "fa-solid fa-comments",
      "BatchMaxRequestCount": null,
      "BatchRequestWaitTime": null,
      "Configuration": {
        "AuthFlow": "api-key",
        "AuthHeaderPattern": "Authorization: Bearer <token>",
        "FileFeedBasePath": "https://app.propfuel.com/dataexport/{AccountID}",
        "FileFeedListPath": "/dataexport/{AccountID}/list",
        "FileFeedDownloadPath": "/dataexport/{AccountID}/download/{file}",
        "FileFeedAckPath": "/dataexport/{AccountID}/ack/{file}",
        "WatermarkMechanism": "microtime-filename-prefix",
        "WatermarkDescription": "Files are named [microtime]-[datatype].json where microtime is Unix seconds with sub-second precision (e.g. 1777565710.1224). Files are returned by the list endpoint in chronological order. The connector advances its watermark by acknowledging processed files via POST /dataexport/{AccountID}/ack/{file}. The highest-microtime successfully-acked file is the durable cursor.",
        "WatermarkSampleFilenames": [
          "1777565710.1224-checkin_questions.json",
          "1777565714.4161-clicks.json",
          "1777565718.7132-opens.json"
        ],
        "PaginationDefaults": {
          "type": "none",
          "note": "File list endpoint returns all available unacked files in a single response; no page cursor or offset needed."
        },
        "IncrementalSyncCapability": true,
        "IncrementalSyncNote": "Incremental sync is driven by the microtime filename prefix. The connector processes files in chronological order (oldest first) and advances the watermark by acking each file after full processing. Partial failure leaves the watermark unchanged; the next sync resumes from the same point.",
        "WebhooksAvailable": false,
        "BulkOperationsAvailable": false,
        "APIVersioningStrategy": "none",
        "TokenRefreshStrategy": "none",
        "ErrorResponseShape": {
          "note": "Not documented by vendor. Standard HTTP status codes. 401 on invalid token, 404 on unknown file."
        },
        "WriteCapability": {
          "Create": false,
          "Update": false,
          "Delete": false,
          "AckCursorAdvance": true,
          "AckNote": "POST /dataexport/{AccountID}/ack/{file} marks a file as consumed (cursor advance only). This is feed-management, NOT record-level write. MUST NOT be called during testing."
        },
        "ConcurrencyControl": "none",
        "DeleteSemantics": "soft",
        "DeleteSemanticsDetail": {
          "checkin_questions": "soft — deleted_at field is set on tombstoned records. Connector must upsert-by-identity (checkin_question.id) and treat deleted_at != null as a tombstone.",
          "clicks": "none — insert-only event stream; no delete mechanism.",
          "opens": "none — insert-only event stream; no delete mechanism."
        },
        "DefaultSyncDirection": "Pull",
        "DefaultConflictResolution": "SourceWins",
        "DefaultConflictResolutionNote": "No ETag or version field on file-feed records; MostRecent cannot be safely applied. In practice this connector is pull-only and conflict resolution is not exercised.",
        "universalPK": {
          "note": "Per-stream PK. All are integer id fields on the root-level record object.",
          "checkin_questions": "checkin_question.id",
          "clicks": "click.id",
          "opens": "open.id"
        },
        "FeedSchedule": "approximately once per hour",
        "DataStreams": [
          "checkin_questions",
          "clicks",
          "opens"
        ],
        "DataStreamNote": "Exact filename token strings confirmed from live broker results: 1777565710.1224-checkin_questions.json, 1777565714.4161-clicks.json, 1777565718.7132-opens.json. (BrokerResultRef: propfuel-probe-1780682837)",
        "MutableStreams": {
          "checkin_questions": {
            "mutations": [
              "create",
              "update",
              "delete"
            ],
            "upsertKey": "checkin_question.id",
            "tombstoneField": "deleted_at",
            "note": "Records created when question is sent, updated when answered, deleted on bot-click detection or multiple answers. Connector MUST upsert by checkin_question.id and apply tombstones.",
            "liveScanEvidence": "518 answered records, 517 with updated_at != created_at, 1 recurring identity in 2318-record scan (propfuel-lifecycle-1780683380)."
          },
          "clicks": {
            "mutations": [
              "create"
            ],
            "note": "Insert-only event stream. No update_at or deleted_at analogues. No recurrence observed in scan."
          },
          "opens": {
            "mutations": [
              "create"
            ],
            "note": "Insert-only event stream. No update_at or deleted_at analogues. No recurrence observed in scan."
          }
        },
        "CredentialFields": [
          "Token",
          "AccountID"
        ],
        "CredentialNote": "Token: bearer token for Authorization header. AccountID: numeric tenant ID embedded in all URL paths (e.g. 2019). Both are required.",
        "BrokerResultRefs": [
          "propfuel-probe-1780682837",
          "propfuel-health-1780689140"
        ]
      }
    },
