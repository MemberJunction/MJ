{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "UserId": {
      "type": "string",
      "title": "User ID",
      "description": "MagnetMail numeric user/account identifier.",
      "order": 0
    },
    "Password": {
      "type": "string",
      "title": "Password",
      "description": "MagnetMail account password.",
      "isSecret": true,
      "order": 1
    },
    "Endpoint": {
      "type": "string",
      "title": "Endpoint",
      "description": "Optional endpoint override. Default: https://hlma-apie1.magnetmail.net/mmapi.asmx.",
      "order": 2
    }
  },
  "required": [
    "UserId",
    "Password"
  ]
}
