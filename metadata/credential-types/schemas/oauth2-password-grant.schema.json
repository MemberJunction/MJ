{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "OAuth2 Password Grant",
  "description": "OAuth2 Resource Owner Password Credentials grant. The connector exchanges a username/password (plus client credentials) at the token endpoint for an access token.",
  "properties": {
    "TokenURL": { "type": "string", "title": "Token URL", "description": "OAuth2 token endpoint." },
    "ClientID": { "type": "string", "title": "Client ID" },
    "ClientSecret": { "type": "string", "title": "Client Secret", "format": "password" },
    "Username": { "type": "string", "title": "Username" },
    "Password": { "type": "string", "title": "Password", "format": "password" },
    "Scope": { "type": "string", "title": "Scope", "description": "Optional space-delimited scopes." }
  },
  "required": ["TokenURL", "ClientID", "ClientSecret", "Username", "Password"],
  "additionalProperties": true
}
