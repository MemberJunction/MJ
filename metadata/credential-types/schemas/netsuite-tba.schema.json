{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "AccountID": {
      "type": "string",
      "title": "Account ID",
      "description": "NetSuite account identifier (e.g., 1234567 or TSTDRV1234567)",
      "isSecret": false,
      "order": 0
    },
    "ConsumerKey": {
      "type": "string",
      "title": "Consumer Key",
      "description": "OAuth 1.0 TBA consumer key from the integration record",
      "isSecret": false,
      "order": 1
    },
    "ConsumerSecret": {
      "type": "string",
      "title": "Consumer Secret",
      "description": "OAuth 1.0 TBA consumer secret",
      "isSecret": true,
      "order": 2
    },
    "TokenID": {
      "type": "string",
      "title": "Token ID",
      "description": "OAuth 1.0 TBA access token ID (non-expiring)",
      "isSecret": false,
      "order": 3
    },
    "TokenSecret": {
      "type": "string",
      "title": "Token Secret",
      "description": "OAuth 1.0 TBA access token secret",
      "isSecret": true,
      "order": 4
    }
  },
  "required": ["AccountID", "ConsumerKey", "ConsumerSecret", "TokenID", "TokenSecret"]
}
