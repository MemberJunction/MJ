  {
    "fields": {
      "Name": "Model Development Agent",
      "CategoryID": "@lookup:MJ: AI Agent Categories.Name=Research and Analysis",
      "Description": "Conversational Loop orchestrator for Predictive Studio. Collaborates with a business user to build a strongly-typed ModelingPlanSpec via three specialist sub-agents (Goal Analyst, Data Scout, Experiment Designer), gates on explicit user approval, then drives the deterministic experiment session through the Run Experiment Session action (train/score/leaderboard/prune within budget), enforces the leakage warn/sign-off rule before any promotion, and authors an ML Experiment Results artifact with drill-through to the winning models. Mirrors the Agent Manager pattern: collaborate -> typed plan -> approve -> deterministic execution -> LLM report.",
      "TypeID": "@lookup:MJ: AI Agent Types.Name=Loop",
      "Status": "Active",
      "ExecutionOrder": 0,
      "ModelSelectionMode": "Agent",
      "ArtifactCreationMode": "Always",
      "DefaultArtifactTypeID": "@lookup:MJ: Artifact Types.Name=ML Experiment Results",
      "ExposeAsAction": true,
      "DriverClass": "PredictiveStudioModelDevAgent",
      "IconClass": "fa-solid fa-flask-vial",
      "InjectNotes": true,
      "MaxNotesToInject": 10,
      "NoteInjectionStrategy": "Relevant",
      "PayloadSelfWritePaths": [
        "Approved",
        "Leaderboard"
      ]
    },
