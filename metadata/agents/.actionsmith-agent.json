      "MJ: AI Agent Relationships": [
        {
          "_comment": "Codesmith is a referenced sub-agent — it remains a top-level agent with its own ExposeAsAction=true, while also being callable from ActionSmith for delegated code generation. SubAgentOutputMapping pulls Codesmith's top-level `code` field directly into ActionSmith's payload under `code` — without this, ActionSmith has to manually re-read the Codesmith response text across multiple LLM iterations to extract the code, wasting tokens and iterations.",
          "fields": {
            "AgentID": "@parent:ID",
            "SubAgentID": "@lookup:MJ: AI Agents.Name=Codesmith Agent",
            "Status": "Active",
            "SubAgentOutputMapping": "{ \"code\": \"code\" }"
