[
  {
    "_comments": [
      "ActionSmith — top-level Runtime-action-builder agent.",
      "ExposeAsAction=true so it's invokable from the action catalog.",
      "Linked to Agent Manager via MJ: AI Agent Sub-Agents (the referenced-sub-agent",
      "relationship, NOT ParentID, because ParentID+ExposeAsAction are mutually exclusive).",
      "Links Codesmith Agent as a sub-agent for delegated code generation + iteration."
    ],
    "fields": {
      "Name": "ActionSmith",
      "CategoryID": "@lookup:MJ: AI Agent Categories.Name=Content Creation",
      "Description": "Meta-agent that builds new Runtime actions for the MemberJunction action catalog. Defines the contract (inputs, outputs, minimal permissions, result codes, test cases), delegates code generation to Codesmith, runs tests via the sandbox, and persists the action for human approval. Ship capability gaps into the catalog without a developer in the loop.",
      "TypeID": "@lookup:MJ: AI Agent Types.Name=Loop",
      "DriverClass": "ActionSmithAgent",
      "Status": "Active",
      "ModelSelectionMode": "Agent",
      "ExposeAsAction": true,
      "InvocationMode": "Any",
      "IconClass": "fa-solid fa-wand-magic-sparkles",
      "PayloadSelfWritePaths": "[\"name\", \"description\", \"inputSchema\", \"outputSchema\", \"permissions\", \"resultCodes\", \"testCases\", \"limits\", \"code\", \"testResults\", \"iterationsUsed\", \"actionId\", \"approvalStatus\", \"status\", \"message\"]",
      "FinalPayloadValidation": "{\"status\": \"string:!empty\", \"actionId\": \"any\", \"testResults\": \"any\"}",
      "FinalPayloadValidationMode": "Warn",
      "MaxIterationsPerRun": 20
    },
