{
  "Transport": "http",
  "ConfigUrlKey": "BaseURL",
  "Configuration": {
    "ClientId": "fixture-client",
    "ClientSecret": "fixture-secret",
    "RefreshToken": "fixture-refresh"
  },
  "Objects": [
    { "Name": "Contact" },
    { "Name": "Group" }
  ],
  "Routes": [
    { "Path": "/oauth/token", "Method": "POST", "Status": 200,
      "Body": { "access_token": "fixture-token", "token_type": "Bearer", "expires_in": 3600 } },
    { "Path": "/api/contacts", "Status": 200,
      "Body": { "TotalRecordAvailable": 2, "Results": [
        { "ContactId": 1001, "ContactName": "Fixture Org A", "ContactType": "{{Business}}", "MembershipStatusTypeId": 2, "SelectionId": 9001 },
        { "ContactId": 1002, "ContactName": "Fixture Person B", "ContactType": "{{Individual}}", "MembershipStatusTypeId": 1, "SelectionId": 9002 }
      ] } },
    { "Path": "/api/groups/all", "Status": 200,
      "Body": { "TotalRecordAvailable": 1, "Results": [
        { "GroupId": 51, "Name": "Fixture Group", "GroupTypeId": 3 }
      ] } }
  ]
}
