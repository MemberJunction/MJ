{
  "name": "@memberjunction/integration-engine",
  "type": "module",
  "version": "5.34.1",
  "description": "MemberJunction Integration Engine - orchestration, field mapping, and connector framework",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth-helpers": {
      "types": "./dist/auth-helpers/index.d.ts",
      "default": "./dist/auth-helpers/index.js"
    },
    "./type-helpers": {
      "types": "./dist/type-helpers/index.d.ts",
      "default": "./dist/type-helpers/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "/dist"
  ],
  "scripts": {
    "build": "tsc && tsc-alias -f",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@memberjunction/core": "5.34.1",
    "@memberjunction/core-entities": "5.34.1",
