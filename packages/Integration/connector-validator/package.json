{
  "name": "@memberjunction/connector-validator",
  "version": "5.34.1",
  "description": "Four-invariant validator CLI for MJ integration connectors. Verifies provable-only emissions, three-way name match, FK metadata correctness, and capability-method match before push.",
  "type": "module",
  "bin": {
    "mj-validate-invariants": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "/dist"
  ],
  "scripts": {
    "build": "tsc && tsc-alias -f",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ts-morph": "^22.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
