{
  "$schema": "../../../../node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/main-*.js",
          "/polyfills-*.js",
          "/styles-*.css"
        ]
      }
    },
    {
      "name": "lazy-chunks",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/chunk-*.js"
        ]
      }
    },
    {
      "name": "lazy-assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/media/**",
          "/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2|ico)"
        ]
      }
    }
  ],
  "navigationUrls": [
    "/**",
    "!/**/graphql",
    "!/**/graphql-ws",
    "!/api/**",
    "!/auth/**",
    "!/**/?msal*",
    "!/**/*__*"
  ]
}
