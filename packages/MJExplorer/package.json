{
  "name": "mj_explorer",
  "description": "MemberJunction Explorer UI",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "NODE_OPTIONS=--max-old-space-size=16384 ng serve --port 4201",
    "start:stage": "NODE_OPTIONS=--max-old-space-size=16384 ng serve --configuration staging",
    "prestart": "mj codegen manifest --exclude-packages @memberjunction --output ./src/app/generated/class-registrations-manifest.ts",
    "prebuild": "mj codegen manifest --exclude-packages @memberjunction --output ./src/app/generated/class-registrations-manifest.ts || echo 'Warning: mj codegen manifest not available, using existing manifest'",
    "build": "NODE_OPTIONS=--max-old-space-size=16384 ng build",
    "postbuild": "node ../../node_modules/@memberjunction/ng-explorer-service-worker/scripts/verify-sw-cache-shape.js dist/MJExplorer/browser",
    "build:stage": "NODE_OPTIONS=--max-old-space-size=16384 ng build --configuration staging",
    "watch": "NODE_OPTIONS=--max-old-space-size=16384 ng build --watch --configuration development",
    "test": "echo \"No tests configured yet\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.1.3",
    "@angular/common": "21.1.3",
    "@angular/core": "21.1.3",
    "@angular/forms": "21.1.3",
    "@angular/localize": "21.1.3",
    "@angular/platform-browser": "21.1.3",
    "@angular/platform-browser-dynamic": "21.1.3",
    "@angular/router": "21.1.3",
    "@azure/msal-angular": "^5.0.3",
    "@azure/msal-browser": "^5.1.0",
    "@dagrejs/dagre": "^1.1.8",
    "@memberjunction/core": "5.40.0",
    "@memberjunction/core-entities": "5.40.0",
    "@memberjunction/global": "5.40.0",
    "@memberjunction/graphql-dataprovider": "5.40.0",
    "@memberjunction/ng-auth-services": "5.40.0",
    "@memberjunction/ng-base-application": "5.40.0",
    "@memberjunction/ng-base-forms": "5.40.0",
    "@memberjunction/ng-bootstrap": "5.40.0",
    "@memberjunction/ng-bootstrap-lite": "5.40.0",
    "@memberjunction/ng-core-entity-forms": "5.40.0",
    "@memberjunction/ng-dashboards": "5.40.0",
    "@memberjunction/ng-explorer-app": "5.40.0",
    "@memberjunction/ng-explorer-core": "5.40.0",
    "@memberjunction/ng-explorer-modules": "5.40.0",
    "@memberjunction/ng-explorer-settings": "5.40.0",
    "@memberjunction/ng-join-grid": "5.40.0",
    "@memberjunction/ng-link-directives": "5.40.0",
    "@memberjunction/ng-record-changes": "5.40.0",
    "@memberjunction/ng-shared": "5.40.0",
    "@memberjunction/ng-timeline": "5.40.0",
    "@memberjunction/ng-workspace-initializer": "5.40.0",
    "@okta/okta-auth-js": "^7.14.1",
    "ag-grid-angular": "^35.0.1",
    "ag-grid-community": "^35.0.1",
    "dhtmlx-gantt": "^9.1.1",
    "golden-layout": "^2.6.0",
    "hammerjs": "^2.0.8",
    "mj_generatedentities": "1.0.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.1.3",
    "@angular/cli": "21.1.3",
    "@angular/compiler-cli": "21.1.3",
    "@types/body-parser": "^1.19.6",
    "typed-assert": "^1.0.9",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@lmdb/lmdb-darwin-arm64": "3.0.8",
    "@lmdb/lmdb-darwin-x64": "3.0.8",
    "@lmdb/lmdb-linux-arm": "3.0.8",
    "@lmdb/lmdb-linux-arm64": "3.0.8",
    "@lmdb/lmdb-linux-x64": "3.0.8",
    "@lmdb/lmdb-win32-x64": "3.0.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MemberJunction/MJ"
  }
}
