{
  "version": "1.0.0",
  "database": {
    "provider": "sqlserver",
    "server": "sql-claude",
    "port": 1433,
    "database": "AW_Stripped",
    "user": "sa",
    "password": "Claude2Sql99",
    "encrypt": true,
    "trustServerCertificate": true,
    "connectionTimeout": 30000
  },
  "ai": {
    "provider": "gemini",
    "model": "gemini-3-flash-preview",
    "apiKey": "AIzaSyAy0-BvzZp-BYpTDWmOr-M24W5Pa9oJw3M",
    "temperature": 0.1,
    "maxTokens": 8000,
    "modelOverrides": {
      "fkPruning": {
        "model": "gemini-3.1-pro-preview",
        "temperature": 0.05,
        "maxTokens": 32000,
        "effortLevel": 100
      }
    },
    "retry": {
      "maxRetries": 5,
      "initialDelayMs": 30000,
      "maxDelayMs": 480000,
      "backoffMultiplier": 2
    }
  },
  "analysis": {
    "cardinalityThreshold": 20,
    "sampleSize": 10,
    "includeStatistics": true,
    "includePatternAnalysis": true,
    "convergence": {
      "maxIterations": 2,
      "stabilityWindow": 2,
      "confidenceThreshold": 0.85
    },
    "backpropagation": {
      "enabled": true,
      "maxDepth": 3
    },
    "sanityChecks": {
      "dependencyLevel": false,
      "schemaLevel": false,
      "crossSchema": false
    },
    "guardrails": {
      "enabled": true,
      "stopOnExceeded": true,
      "maxTokensPerRun": 10000000,
      "maxDurationSeconds": 10800,
      "maxCostDollars": 50,
      "maxTokensPerPhase": {
        "discovery": 4000000,
        "analysis": 5000000,
        "sanityChecks": 2000000
      },
      "maxTokensPerIteration": 2000000,
      "maxIterationDurationSeconds": 1800,
      "warnThresholds": {
        "tokenPercentage": 80,
        "durationPercentage": 80,
        "costPercentage": 80,
        "iterationTokenPercentage": 85,
        "phaseTokenPercentage": 85
      }
    },
    "relationshipDiscovery": {
      "enabled": true,
      "triggers": {
        "runOnMissingPKs": true,
        "runOnInsufficientFKs": true,
        "fkDeficitThreshold": 0.4
      },
      "tokenBudget": {
        "ratioOfTotal": 0.4
      },
      "confidence": {
        "primaryKeyMinimum": 0.7,
        "foreignKeyMinimum": 0.6,
        "llmValidationThreshold": 0.8
      },
      "sampling": {
        "maxRowsPerTable": 1000,
        "valueOverlapSampleSize": 500,
        "statisticalSignificance": 100,
        "compositeKeyMaxColumns": 3
      },
      "patterns": {
        "primaryKeyNames": [
          "^id$",
          ".*_id$",
          "^pk_.*",
          ".*_key$"
        ],
        "foreignKeyNames": [
          ".*_id$",
          ".*_fk$",
          "^fk_.*"
        ]
      },
      "llmValidation": {
        "enabled": true,
        "batchSize": 10
      },
      "backpropagation": {
        "enabled": true,
        "maxIterations": 5
      }
    },
    "sampleQueryGeneration": {
      "enabled": false
    }
  },
  "output": {
    "stateFile": "./autodoc-output/run-015/state.json",
    "outputDir": "./autodoc-output/run-015",
    "sqlFile": "./autodoc-output/run-015/extended-props.sql",
    "markdownFile": "./autodoc-output/run-015/summary.md"
  },
  "schemas": {
    "exclude": [
      "sys",
      "INFORMATION_SCHEMA"
    ]
  },
  "tables": {
    "exclude": [
      "sysdiagrams"
    ]
  }
}