# LearnWorlds Integration Test Configuration
# Copy this file to .env.integration and fill in real values.
#
# Then run:  npm run test:integration

# Required — set to "true" to enable the integration tests
LW_INTEGRATION=true

# Your LearnWorlds school domain (e.g. "yourschool.learnworlds.com")
LW_SCHOOL_DOMAIN=

# API key from LearnWorlds Admin > Settings > API
LW_API_KEY=

# Client ID (Lw-Client header). If blank, falls back to SCHOOL_DOMAIN.
LW_CLIENT_ID=

# Arbitrary company ID used as a key for env-var credential lookup.
# Must be a valid UUID format (used for SQL injection prevention in credential lookups).
LW_COMPANY_ID=00000000-0000-0000-0000-000000000001

# A real course ID in your LearnWorlds school (for enrollment test).
# Find it in LearnWorlds Admin > Courses > click a course > URL contains the ID.
LW_TEST_COURSE_ID=

# Email for the test user that will be created.
# Leave blank to auto-generate a unique email per run.
LW_TEST_EMAIL=
