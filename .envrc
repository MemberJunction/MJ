# .envrc — direnv activates this when you cd into the MJ directory.
#
# Requires direnv (https://direnv.net) and devenv (https://devenv.sh).
# After cloning the repo: run `direnv allow` once.
#
# Per-worktree port override:
#   Create .envrc.local with: export DEVENV_POSTGRES_PORT=5433
#   (gitignored — each developer/worktree sets their own port)
#
# SQL Server users: this file is for the Nix/PostgreSQL path only.
# SQL Server devs do not need direnv — use the Docker path instead.

# Load per-worktree overrides first (port, local secrets, etc.)
# shellcheck disable=SC1091
[ -f .envrc.local ] && source_env .envrc.local

# Activate the devenv shell (starts PostgreSQL service if not running)
use devenv
